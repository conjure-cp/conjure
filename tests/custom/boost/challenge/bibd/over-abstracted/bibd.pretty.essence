language Essence 1.3

given v: int(1..)
given b: int(1..)
given r: int(1..)
given k: int(1..)
given lambda: int(1..)
find design: relation of (int(1..v) * int(1..b))
such that
    and([sum([toInt((point, block) in design) | block : int(1..b)]) = r | point : int(1..v)]),
    and([sum([toInt((point, block) in design) | point : int(1..v)]) = k | block : int(1..b)]),
    and([and([sum([toInt((p1, block) in design /\ (p2, block) in design) | block : int(1..b)]) = lambda
                  | p2 : int(p1 + 1..v)])
             | p1 : int(1..v)])

