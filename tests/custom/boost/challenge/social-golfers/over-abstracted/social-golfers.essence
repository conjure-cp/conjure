language Essence 1.3

given g, s, w : int(1..)
letting n be g * s

find schedule : matrix indexed by [int(1..w)] of partition (numParts g, partSize s) from int(1..n)

such that
    forAll w1 : int(1..w) . forAll w2 : int(w1+1..w) .
        forAll p1, p2 : int(1..n) . p1 < p2 ->
            !(together({p1, p2}, schedule[w1]) /\ together({p1, p2}, schedule[w2]))
