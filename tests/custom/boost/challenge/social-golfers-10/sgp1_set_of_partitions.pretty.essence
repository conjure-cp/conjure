language Essence 1.3

given w: int(1..)
given g: int(1..)
given s: int(1..)
letting nGolfers be g * s
letting Golfers be new type of size nGolfers
find sched: set (size w) of partition (numParts g, partSize s, regular) from Golfers
such that
    and([and([p1 != p2 -> sum([sum([toInt(p1 in part /\ p2 in part) | part <- parts(week)]) | week <- sched]) <= 1
                  | p2 : Golfers])
             | p1 : Golfers])

