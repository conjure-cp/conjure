language Essence 1.3

given numGuests: int(1..)
given numHosts: int(1..)
given numPeriods: int(1..)
given guestCrew: matrix indexed by [int(1..numGuests)] of int(1..)
given hostCap: matrix indexed by [int(1..numHosts)] of int(1..)
find schedule: matrix indexed by [int(1..numPeriods), int(1..numGuests)] of int(1..numHosts)
such that
    and([and([sum([toInt(schedule[p, g] = h) * guestCrew[g] | g : int(1..numGuests)]) <= hostCap[h]
                  | p : int(1..numPeriods)])
             | h : int(1..numHosts)]),
    and([and([and([schedule[p1, g] != schedule[p2, g] | p2 : int(p1 + 1..numPeriods)]) | p1 : int(1..numPeriods)])
             | g : int(1..numGuests)]),
    and([and([sum([toInt(schedule[p, g1] = schedule[p, g2]) | p : int(1..numPeriods)]) <= 1
                  | g2 : int(g1 + 1..numGuests)])
             | g1 : int(1..numGuests)])

