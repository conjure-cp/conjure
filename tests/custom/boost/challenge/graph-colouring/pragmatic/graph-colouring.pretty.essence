language Essence 1.3

given n: int(1..)
given k: int(1..)
given edges: set of set (size 2) of int(1..n)
find colour: matrix indexed by [int(1..n)] of int(1..k)
such that
    and([and([and([u < v -> colour[u] != colour[v] | v <- edge]) | u <- edge]) | edge <- edges]),
    and([and([colour[v] = c -> or([colour[v2] = c - 1 | v2 : int(1..v - 1)]) | v : int(1..n)]) | c : int(2..k)])

