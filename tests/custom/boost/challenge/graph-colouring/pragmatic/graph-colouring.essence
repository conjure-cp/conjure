language Essence 1.3

given n, k : int(1..)
given edges : set of set (size 2) of int(1..n)

find colour : matrix indexed by [int(1..n)] of int(1..k)

such that
    forAll edge in edges .
        forAll u in edge . forAll v in edge . u < v ->
            colour[u] != colour[v],
    $ Value precedence: colour c is used only if some earlier-indexed vertex uses c-1
    forAll c : int(2..k) .
        forAll v : int(1..n) . colour[v] = c ->
            (exists v2 : int(1..v-1) . colour[v2] = c - 1)
