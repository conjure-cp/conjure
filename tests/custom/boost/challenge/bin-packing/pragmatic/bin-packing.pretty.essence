language Essence 1.3

given numItems: int(1..)
given itemSize: matrix indexed by [int(1..numItems)] of int(1..)
given binCap: int(1..)
letting maxBins be numItems
find assignment: matrix indexed by [int(1..numItems)] of int(1..maxBins)
find numBins: int(1..maxBins)
minimising numBins
such that
    and([sum([toInt(assignment[item] = bin) * itemSize[item] | item : int(1..numItems)]) <= binCap
             | bin : int(1..maxBins)]),
    and([assignment[item] <= numBins | item : int(1..numItems)]),
    and([or([assignment[item] = bin | item : int(1..numItems)]) ->
         or([assignment[item2] = bin - 1 | item2 : int(1..numItems)])
             | bin : int(2..maxBins)]),
    assignment[1] = 1

