language Essence 1.3

given numItems : int(1..)
given itemSize : matrix indexed by [int(1..numItems)] of int(1..)
given binCap : int(1..)

letting maxBins be numItems

find assignment : matrix indexed by [int(1..numItems)] of int(1..maxBins)
find numBins : int(1..maxBins)

minimising numBins

such that
    forAll bin : int(1..maxBins) .
        (sum item : int(1..numItems) . toInt(assignment[item] = bin) * itemSize[item]) <= binCap,
    forAll item : int(1..numItems) .
        assignment[item] <= numBins,
    $ Consecutive-bin symmetry breaking: items use bins 1..numBins contiguously
    forAll bin : int(2..maxBins) .
        (exists item : int(1..numItems) . assignment[item] = bin) ->
            (exists item2 : int(1..numItems) . assignment[item2] = bin - 1),
    $ First item goes in bin 1
    assignment[1] = 1
