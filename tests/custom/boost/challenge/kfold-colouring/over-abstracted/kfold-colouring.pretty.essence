language Essence 1.3

given n: int(1..)
given k: int(1..)
given numColours: int(1..)
given edges: set of set (size 2) of int(1..n)
find colouring: function (total) int(1..n) --> mset (size k, maxOccur 1) of int(1..numColours)
such that
    and([and([and([u < v -> and([!(c in image(colouring, u) /\ c in image(colouring, v)) | c : int(1..numColours)])
                       | v <- edge])
                  | u <- edge])
             | edge <- edges])

